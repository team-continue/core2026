<robot name="core2025_attacker">
    <gazebo>
        <plugin name="CoreOmniDrive" filename="libcore_gz_omnidrive_plugin.so">
        <!-- パラメータをここに記述 -->
        <!-- <param_name>param_value</param_name> -->
        </plugin>
    </gazebo>
    <link name="base_link">
        <visual>
            <geometry>
                <mesh filename="package://core_gz/urdf/mesh/Attacker_Shooter.dae"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://core_gz/urdf/mesh/Attacker_Shooter.dae"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
    </link>

    <link name="chassis_link">
        <visual>
            <geometry>
                <mesh filename="package://core_gz/urdf/mesh/Attacker_Chassis.dae"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://core_gz/urdf/mesh/Attacker_Chassis.dae"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.05"/>
        </inertial>
    </link>

    <link name="upperwing_link">
        <visual>
            <geometry>
                <mesh filename="package://core_gz/urdf/mesh/Attacker_UpperWing.dae"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://core_gz/urdf/mesh/Attacker_UpperWing.dae"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>

    <link name="camera0_link">
    </link>

    <link name="camera1_link">
    </link>

    <joint name="base_to_chassis" type="continuous">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="base_to_camera1" type="fixed">
        <parent link="base_link"/>
        <child link="camera1_link"/>
        <origin xyz="0.0824 -0.1713 0.6860" rpy="0 0 0"/>
    </joint>

    <joint name="base_to_upperwing" type="revolute">
        <axis xyz="0 -1 0"/>
        <limit effort="1000.0" lower="-0.78" upper="0.78" velocity="0.1"/>
        <parent link="base_link"/>
        <child link="upperwing_link"/>
        <origin xyz="0.1635 0.1761 0.226833" rpy="0 0 0"/>
    </joint>

    <joint name="upperwing_to_camera0" type="fixed">
        <parent link="upperwing_link"/>
        <child link="camera0_link"/>
        <origin xyz="0.0208 -0.0945  0.0262" rpy="0 0 0"/>
    </joint>
</robot>