[Unit]
Description=CoRE hardware EtherCAT daemon
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
ExecStart=@CORE_HARDWARE_DAEMON_PATH@ --if-name @CORE_HARDWARE_IF_NAME@ --socket-path @CORE_HARDWARE_SOCKET_PATH@
Restart=on-failure
RestartSec=1
WorkingDirectory=/

[Install]
WantedBy=multi-user.target
